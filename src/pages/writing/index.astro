---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/BaseLayout.astro';
import FilterToolbar from '../../components/FilterToolbar.astro';
import PostCard from '../../components/PostCard.astro';
import { siteMeta } from '../../data/site';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const tags = [...new Set(posts.flatMap((entry) => entry.data.tags))].sort();
---

<BaseLayout title={`Writing | ${siteMeta.name}`} description="Research notes and essays.">
	<section class="reveal pb-8 pt-3 md:pb-10 md:pt-5">
		<p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[var(--text-muted)]">Archive</p>
		<h1 class="mt-3 text-[2.75rem] leading-[1.02] md:text-[3.8rem]">Writing / Notes</h1>
		<p class="mt-4 max-w-3xl text-sm leading-7 text-[var(--text-muted)]">
			Essays and implementation notes that sit between lab notebook, design memo, and public reflection.
		</p>
	</section>

	<section>
		{
			posts.length > 0 ? (
				<>
					<FilterToolbar group="writing" title="Filter by topic" tags={tags} />
					<div class="dim-list">
						{
							posts.map((entry) => (
								<div data-filter-item="writing" data-tags={entry.data.tags.join('|')}>
									<PostCard entry={entry} />
								</div>
							))
						}
					</div>
				</>
			) : (
				<div class="reveal border-t border-b border-[var(--border-fine)] py-6 text-sm leading-7 text-[var(--text-muted)]">
					No writing has been published yet.
				</div>
			)
		}
	</section>
</BaseLayout>
