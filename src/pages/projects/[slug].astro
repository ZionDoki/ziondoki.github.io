---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../components/BaseLayout.astro';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { data } = entry;
---

<BaseLayout title={`${data.name} | Projects`} description={data.summary}>
	<article class="pb-12">
		<a class="link-underline reveal font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--text-muted)]" href="/projects/">
			← Back to projects
		</a>
		<header class="reveal mt-6 max-w-4xl pb-2">
			<p class="font-mono text-[11px] uppercase tracking-[0.28em] text-[var(--text-muted)]">{data.status}</p>
			<h1 class="mt-4 text-[3.1rem] leading-[1.03] md:text-[4.5rem]">{data.name}</h1>
			<p class="mt-6 max-w-3xl text-base leading-8 text-[var(--text-muted)]">{data.summary}</p>
			<div class="mt-8 flex flex-wrap gap-x-5 gap-y-3 font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--text-muted)]">
				{data.repo && (
					<a class="link-underline" href={data.repo} target="_blank" rel="noreferrer">
						Repository
					</a>
				)}
				{data.demo && (
					<a class="link-underline" href={data.demo} target="_blank" rel="noreferrer">
						Live demo
					</a>
				)}
			</div>
		</header>
		<div class="mt-16 grid gap-14 md:grid-cols-12">
			<div class="prose-academic reveal md:col-span-8">
				<Content />
			</div>
			<aside class="reveal border-t border-[var(--border-fine)] pt-6 md:col-span-4 md:border-l md:border-t-0 md:pl-8 md:pt-0">
				<p class="font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--text-muted)]">Project posture</p>
				<ul class="mt-5 space-y-4 text-sm leading-7 text-[var(--text-muted)]">
					<li>Status: {data.status}</li>
					<li>Repository: public and intended for reference use</li>
					<li>Primary mode: maintainable research software</li>
				</ul>
			</aside>
		</div>
	</article>
</BaseLayout>
