---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/BaseLayout.astro';
import FilterToolbar from '../../components/FilterToolbar.astro';
import PublicationCard from '../../components/PublicationCard.astro';
import { siteMeta } from '../../data/site';

const publications = (await getCollection('publications')).sort((a, b) => {
	const aYear = typeof a.data.year === 'number' ? a.data.year : 9999;
	const bYear = typeof b.data.year === 'number' ? b.data.year : 9999;
	return bYear - aYear;
});
const tags = [...new Set(publications.flatMap((entry) => entry.data.tags))].sort();
---

<BaseLayout title={`Publications | ${siteMeta.name}`} description="Selected and archived publications.">
	<section class="reveal pb-8 pt-3 md:pb-10 md:pt-5">
		<p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[var(--text-muted)]">Archive</p>
		<h1 class="mt-3 text-[2.75rem] leading-[1.02] md:text-[3.8rem]">Publications</h1>
		<p class="mt-4 max-w-3xl text-sm leading-7 text-[var(--text-muted)]">
			A curated publication index with MDX detail pages for abstracts, notes, links, and citation-ready metadata.
		</p>
		<a class="link-underline mt-5 inline-flex font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--text-muted)]" href="/publications.bib">
			Download publications.bib &rarr;
		</a>
	</section>

	<section>
		<FilterToolbar group="publications" title="Filter by topic" tags={tags} />
		<div class="dim-list">
			{
				publications.map((entry) => (
					<div data-filter-item="publications" data-tags={entry.data.tags.join('|')}>
						<PublicationCard entry={entry} />
					</div>
				))
			}
		</div>
	</section>
</BaseLayout>
