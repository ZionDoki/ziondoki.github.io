---
import { getCollection } from 'astro:content';
import BaseLayout from '../components/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PublicationCard from '../components/PublicationCard.astro';
import SectionShell from '../components/SectionShell.astro';
import { cvSummary, homeIntro, siteMeta } from '../data/site';

const publications = (await getCollection('publications'))
	.filter((entry) => entry.data.featured)
	.sort((a, b) => {
		const aYear = typeof a.data.year === 'number' ? a.data.year : 9999;
		const bYear = typeof b.data.year === 'number' ? b.data.year : 9999;
		return bYear - aYear;
	})
	.slice(0, 3);

const projects = (await getCollection('projects'))
	.filter((entry) => entry.data.featured)
	.slice(0, 3);

const posts = (await getCollection('posts', ({ data }) => !data.draft))
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
	.slice(0, 2);
---

<BaseLayout isHome title={`${siteMeta.name} | ${siteMeta.title}`} description={siteMeta.description}>
	<section id="about" data-section class="pb-10 pt-3 md:pb-12 md:pt-5">
		<div class="reveal border-b border-[var(--border-fine)] pb-8 md:pb-9">
			<p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[var(--text-muted)]">
				Academic Homepage
			</p>
			<div class="mt-5 grid gap-8 md:grid-cols-[minmax(0,1.28fr)_minmax(260px,0.72fr)] md:items-start">
				<div>
					<h1 class="text-[3rem] leading-[0.98] md:text-[4rem]">{siteMeta.name}</h1>
					<p class="mt-3 max-w-2xl text-[1.08rem] leading-7 text-[var(--text-muted)] md:text-[1.22rem]">
						{siteMeta.title}
					</p>
					<p class="mt-4 max-w-2xl font-serif text-base leading-7 italic text-[color:rgba(17,17,17,0.72)]">
						The superior man acts with resolve and nurtures virtue.
					</p>
					<div class="mt-6 grid max-w-3xl gap-3">
						{homeIntro.map((paragraph) => <p class="text-[15px] leading-7 text-[var(--text-muted)]">{paragraph}</p>)}
					</div>
				</div>

				<div class="border-t border-[var(--border-fine)] md:pt-0">
					<div class="grid grid-cols-[108px_minmax(0,1fr)] gap-4 border-b border-[var(--border-fine)] py-3.5">
						<p class="font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--text-muted)]">Affiliation</p>
						<p class="text-sm leading-6">{siteMeta.affiliation}</p>
					</div>
					<div class="grid grid-cols-[108px_minmax(0,1fr)] gap-4 border-b border-[var(--border-fine)] py-3.5">
						<p class="font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--text-muted)]">Location</p>
						<p class="text-sm leading-6">{siteMeta.location}</p>
					</div>
					<div class="grid grid-cols-[108px_minmax(0,1fr)] gap-4 border-b border-[var(--border-fine)] py-3.5">
						<p class="font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--text-muted)]">Contact</p>
						<p class="text-sm leading-6">
							<a class="link-underline" href={`mailto:${siteMeta.email}`}>{siteMeta.email}</a>
						</p>
					</div>
					<div class="grid grid-cols-[108px_minmax(0,1fr)] gap-4 border-b border-[var(--border-fine)] py-3.5">
						<p class="font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--text-muted)]">Links</p>
						<div class="flex flex-wrap gap-x-4 gap-y-2 font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--text-muted)]">
							<a class="link-underline hover:text-[var(--text-ink)]" href={siteMeta.cvHref}>CV</a>
							<a class="link-underline hover:text-[var(--text-ink)]" href={siteMeta.repository} target="_blank" rel="noreferrer">Repository</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<SectionShell
		id="publications"
		kicker="Selected Publications"
		title="Selected Publications"
		intro="Representative work on open-source license compatibility, software supply chain security, and trustworthy analysis."
	>
		<Fragment slot="actions">
			<a href="/publications/" class="link-underline">View Index &rarr;</a>
		</Fragment>
		<div class="dim-list">
			{publications.map((entry) => <PublicationCard entry={entry} compact />)}
		</div>
	</SectionShell>

	<SectionShell
		id="projects"
		kicker="Research Projects"
		title="Research Projects and Systems"
		intro="Selected research and engineering efforts spanning industrial collaboration, national projects, and open-source systems."
	>
		<Fragment slot="actions">
			<a href="/projects/" class="link-underline">View Projects &rarr;</a>
		</Fragment>
		<div class="dim-list">
			{projects.map((entry) => <ProjectCard entry={entry} />)}
		</div>
	</SectionShell>

	<SectionShell
		id="writing"
		kicker="Writing"
		title="Writing / Notes"
		intro="Short essays, technical notes, and reflections on research software, scholarly interfaces, and trustworthy systems."
	>
		<Fragment slot="actions">
			<a href="/writing/" class="link-underline">View Writing &rarr;</a>
		</Fragment>
		{
			posts.length > 0 ? (
				<div class="dim-list">
					{posts.map((entry) => <PostCard entry={entry} />)}
				</div>
			) : (
				<div class="reveal border-t border-b border-[var(--border-fine)] py-6 text-sm leading-7 text-[var(--text-muted)]">
					No public essays are posted yet.
				</div>
			)
		}
	</SectionShell>

	<SectionShell
		id="cv"
		kicker="Curriculum Vitae"
		title="Curriculum Vitae"
		intro={cvSummary.statement}
	>
		<Fragment slot="actions">
			<a href={siteMeta.cvHref} class="link-underline">Download CV &rarr;</a>
		</Fragment>
		<div class="grid gap-8 md:grid-cols-12">
			<div class="reveal md:col-span-4">
				<p class="font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--text-muted)]">Education</p>
				<ul class="mt-4 border-t border-[var(--border-fine)]">
					{
						cvSummary.education.map((item) => (
							<li class="border-b border-[var(--border-fine)] py-3.5">
								<p class="font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--text-muted)]">{item.period}</p>
								<p class="mt-2 font-serif text-[1.2rem] leading-tight">{item.title}</p>
								<p class="mt-2 text-sm leading-6 text-[var(--text-muted)]">{item.meta}</p>
							</li>
						))
					}
				</ul>
			</div>
			<div class="reveal md:col-span-4">
				<p class="font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--text-muted)]">Experience</p>
				<ul class="mt-4 border-t border-[var(--border-fine)]">
					{
						cvSummary.experience.map((item) => (
							<li class="border-b border-[var(--border-fine)] py-3.5">
								<p class="font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--text-muted)]">{item.period}</p>
								<p class="mt-2 font-serif text-[1.2rem] leading-tight">{item.title}</p>
								<p class="mt-2 text-sm leading-6 text-[var(--text-muted)]">{item.meta}</p>
							</li>
						))
					}
				</ul>
			</div>
			<div class="reveal md:col-span-4">
				<p class="font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--text-muted)]">Honors & Recognition</p>
				<ul class="mt-4 border-t border-[var(--border-fine)]">
					{
						cvSummary.service.map((item) => (
							<li class="border-b border-[var(--border-fine)] py-3.5 text-sm leading-6 text-[var(--text-muted)]">
								{item}
							</li>
						))
					}
				</ul>
				<a class="link-underline mt-5 inline-flex font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--text-muted)]" href={siteMeta.cvHref}>
					Download full PDF &rarr;
				</a>
			</div>
		</div>
	</SectionShell>
</BaseLayout>
