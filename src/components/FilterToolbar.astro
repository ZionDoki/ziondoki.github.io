---
interface Props {
	group: string;
	title: string;
	tags: string[];
}

const { group, title, tags } = Astro.props;
---

<div
	class="reveal mb-4 flex flex-col gap-3 border-t border-[var(--border-fine)] pt-4 md:mb-6 md:flex-row md:items-center md:justify-between"
	data-filter-group={group}
>
	<p class="font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--text-muted)]">{title}</p>
	<div class="flex flex-wrap gap-x-4 gap-y-2 font-mono text-[11px] uppercase tracking-[0.18em]">
		<button type="button" class="filter-chip" data-filter-value="all" aria-pressed="true">All</button>
		{
			tags.map((tag) => (
				<button type="button" class="filter-chip" data-filter-value={tag} aria-pressed="false">
					{tag}
				</button>
			))
		}
	</div>
</div>
