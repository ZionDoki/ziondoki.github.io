---
import type { CollectionEntry } from 'astro:content';

interface Props {
	entry: CollectionEntry<'posts'>;
}

const { entry } = Astro.props;
const { data, id } = entry;
---

<a href={`/writing/${id}/`} class="group block border-b border-[var(--border-fine)] py-[1.125rem] reveal md:py-5">
	<div class="grid grid-cols-1 gap-3 md:grid-cols-12 md:gap-6">
		<div class="font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--text-muted)] md:col-span-2">
			{data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
		</div>

		<div class="md:col-span-8">
			<h3 class="text-[1.28rem] leading-[1.18] text-[var(--text-ink)] transition-colors duration-700 group-hover:text-[var(--text-muted)] md:text-[1.48rem]">
				{data.title}
			</h3>
			<p class="mt-2.5 max-w-3xl text-sm leading-7 text-[var(--text-muted)]">{data.description}</p>
		</div>

		<div class="mt-1 flex items-center justify-between gap-4 md:col-span-2 md:mt-0 md:justify-end">
			<span class="font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--text-ink)] md:text-right">
				{data.tags.slice(0, 2).join(' // ')}
			</span>
			<span class="flex h-5 w-5 shrink-0 items-center justify-center overflow-hidden">
				<svg
					class="h-3.5 w-3.5 translate-x-[-70%] opacity-0 transition-all duration-700 group-hover:translate-x-0 group-hover:opacity-100"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.5"
				>
					<path d="M7 17L17 7M17 7H7M17 7V17" stroke-linecap="round" stroke-linejoin="round"></path>
				</svg>
			</span>
		</div>
	</div>
</a>
