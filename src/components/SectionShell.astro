---
interface Props {
	id?: string;
	kicker: string;
	title: string;
	intro?: string;
}

const { id, kicker, title, intro } = Astro.props;
---

<section id={id} data-section class="py-8 md:py-10">
	<div class="mb-5 border-b border-[var(--border-fine)] pb-4 md:mb-6 md:flex md:items-end md:justify-between md:gap-8">
		<div class="max-w-4xl reveal">
			<p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[var(--text-muted)]">{kicker}</p>
			<h2 class="mt-2.5 max-w-4xl text-[2rem] leading-[1.08] md:text-[2.45rem]">{title}</h2>
			{intro && <p class="mt-2.5 max-w-2xl text-sm leading-7 text-[var(--text-muted)]">{intro}</p>}
		</div>
		<div class="reveal mt-3 shrink-0 font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--text-muted)] md:mt-0">
			<slot name="actions" />
		</div>
	</div>
	<slot />
</section>
