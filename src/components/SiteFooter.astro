---
import { siteMeta } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--border-fine)]">
	<div class="mx-auto w-full max-w-[980px] px-6 py-10 sm:px-8">
		<div class="flex flex-wrap items-start gap-x-5 gap-y-3 font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--text-muted)]">
			<a class="link-underline hover:text-[var(--text-ink)]" href={`mailto:${siteMeta.email}`}>Email</a>
			<a class="link-underline hover:text-[var(--text-ink)]" href={siteMeta.cvHref}>CV</a>
			<a class="link-underline hover:text-[var(--text-ink)]" href={siteMeta.repository} target="_blank" rel="noreferrer">Repository</a>
			<span>{siteMeta.phone}</span>
			<span>© {year} {siteMeta.name}</span>
		</div>
	</div>
</footer>
