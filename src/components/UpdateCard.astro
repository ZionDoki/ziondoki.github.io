---
import type { CollectionEntry } from 'astro:content';

interface Props {
	entry: CollectionEntry<'updates'>;
}

const { entry } = Astro.props;
const { data } = entry;
---

<a href={data.url} target="_blank" rel="noreferrer" class="group block border-b border-[var(--border-fine)] py-7 md:py-8 reveal">
	<div class="grid grid-cols-1 gap-4 md:grid-cols-12 md:gap-8">
		<div class="font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--text-muted)] md:col-span-2">
			{data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
		</div>

		<div class="md:col-span-7">
			<h3 class="text-[1.55rem] leading-[1.16] text-[var(--text-ink)] transition-colors duration-700 group-hover:text-[var(--text-muted)] md:text-[1.85rem]">
				{data.title}
			</h3>
			<p class="mt-3 max-w-2xl text-[15px] leading-8 text-[var(--text-muted)]">{data.summary}</p>
		</div>

		<div class="mt-3 flex items-center justify-between gap-4 md:col-span-3 md:mt-0 md:justify-end">
			<span class="font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--text-ink)]">
				{data.source}
			</span>
			<span class="flex h-6 w-6 items-center justify-center overflow-hidden">
				<svg
					class="h-4 w-4 translate-x-[-70%] opacity-0 transition-all duration-700 group-hover:translate-x-0 group-hover:opacity-100"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.5"
				>
					<path d="M7 17L17 7M17 7H7M17 7V17" stroke-linecap="round" stroke-linejoin="round"></path>
				</svg>
			</span>
		</div>
	</div>
</a>
