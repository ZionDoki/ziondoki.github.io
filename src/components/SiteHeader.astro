---
import { siteMeta } from '../data/site';

interface Props {
	isHome?: boolean;
	currentPath: string;
}

const { isHome = false, currentPath } = Astro.props;

const navItems = [
	{ label: 'About', href: isHome ? '#about' : '/#about', section: 'about' },
	{ label: 'Publications', href: isHome ? '#publications' : '/publications/', section: 'publications' },
	{ label: 'Projects', href: isHome ? '#projects' : '/projects/', section: 'projects' },
	{ label: 'Writing', href: isHome ? '#writing' : '/writing/', section: 'writing' },
	{ label: 'CV', href: siteMeta.cvHref, section: 'cv' },
];
---

<header
	data-site-header
	class="fixed inset-x-0 top-0 z-40 bg-[color:rgba(249,249,248,0.94)] transition-colors duration-700 ease-[var(--ease-out-expo)]"
>
	<div class="mx-auto flex w-full max-w-[1120px] items-center justify-between gap-6 border-b border-transparent px-5 py-4 sm:px-7">
		<a href="/" class="min-w-0">
			<p class="font-mono text-[10px] uppercase tracking-[0.24em] text-[var(--text-muted)]">
				Research Archive
			</p>
			<p class="mt-1 font-serif text-[1.65rem] leading-none text-[var(--text-ink)]">Ziang Liu</p>
		</a>

		<nav class="hidden items-center gap-5 font-mono text-[11px] uppercase tracking-[0.2em] md:flex" aria-label="Primary">
			{
				navItems.map((item) => (
					<a
						href={item.href}
						data-nav-link
						data-section-target={isHome ? item.section : undefined}
						class:list={[
							'site-nav-link link-underline',
							!isHome && currentPath.startsWith(`/${item.section}`) && item.section !== 'about' && 'is-current',
						]}
					>
						{item.label}
					</a>
				))
			}
		</nav>

		<div class="flex items-center gap-5 font-mono text-[11px] uppercase tracking-[0.2em]">
			<a class="link-underline hidden text-[var(--text-muted)] transition-colors duration-700 hover:text-[var(--text-ink)] md:inline-flex" href="/publications/">
				Archive
			</a>
			<button
				class="text-[var(--text-muted)] transition-colors duration-700 hover:text-[var(--text-ink)] md:hidden"
				type="button"
				aria-expanded="false"
				aria-controls="mobile-menu"
				data-menu-toggle
			>
				Menu
			</button>
		</div>
	</div>

	<div id="mobile-menu" hidden data-menu-panel class="border-t border-[var(--border-fine)] md:hidden">
		<div class="mx-auto flex w-full max-w-[1120px] flex-col gap-4 px-5 py-5 font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--text-muted)] sm:px-7">
			{
				navItems.map((item) => (
					<a
						href={item.href}
						data-mobile-link
						data-section-target={isHome ? item.section : undefined}
						class="link-underline w-fit"
					>
						{item.label}
					</a>
				))
			}
			<a href="/publications/" class="link-underline w-fit">Full archive</a>
		</div>
	</div>
</header>
