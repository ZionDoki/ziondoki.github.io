---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import MotionScript from './MotionScript.astro';
import SiteFooter from './SiteFooter.astro';
import SiteHeader from './SiteHeader.astro';
import { siteMeta } from '../data/site';

interface Props {
	title?: string;
	description?: string;
	isHome?: boolean;
}

const {
	title = `${siteMeta.name} | ${siteMeta.title}`,
	description = siteMeta.description,
	isHome = false,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#f4efe7" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content="/og-cover.svg" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="canonical" href={canonical} />
		<ClientRouter />
		<title>{title}</title>
	</head>
	<body class="min-h-screen bg-[var(--bg-paper)] text-[var(--text-ink)]">
		<div class="relative min-h-screen overflow-x-clip">
			<SiteHeader isHome={isHome} currentPath={Astro.url.pathname} />
			<main class="mx-auto flex w-full max-w-[980px] flex-col px-6 pb-24 pt-28 sm:px-8 md:pt-36">
				<slot />
			</main>
			<SiteFooter />
		</div>
		<MotionScript />
	</body>
</html>
